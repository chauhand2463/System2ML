# System2ML Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# API Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
HOST=0.0.0.0
PORT=8000
ENV=development

# ===========================================
# AI Services (Required for AI Architect)
# ===========================================
GROQ_API_KEY=your_groq_api_key

# ===========================================
# OAuth Authentication (Optional)
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ===========================================
# Database
# ===========================================
DATABASE_URL=sqlite:///./system2ml.db
DB_POOL_SIZE=5

# ===========================================
# CORS (comma-separated origins for production)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=60

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# Session & Security
# ===========================================
SESSION_SECRET=your_session_secret_min_32_chars
JWT_SECRET=your_jwt_secret_min_32_chars

# ===========================================
# Data Configuration
# ===========================================
DATA_PATH=./data
TEST_SIZE=0.2
VALIDATION_SIZE=0.1
RANDOM_SEED=42

# ===========================================
# ML Pipeline Configuration
# ===========================================
TARGET_SCORE=0.9
BUDGET=100.0
CARBON_LIMIT_KG=1.0
MAX_LATENCY_MS=1000
MAX_RETRIES=3

# ===========================================
# MLflow Configuration
# ===========================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_LOCATION=./mlruns

# ===========================================
# Carbon Tracking
# ===========================================
CARBON_OUTPUT_DIR=./carbon_reports

# ===========================================
# Prometheus Monitoring
# ===========================================
PROMETHEUS_PORT=9090

# ===========================================
# Fine-tuning Configuration
# ===========================================
FINETUNE_OUTPUT_DIR=./outputs/finetune
TRAIN_BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=1
NUM_TRAIN_EPOCHS=1
LEARNING_RATE=2e-4
MAX_SEQ_LENGTH=512
LOGGING_STEPS=10

# ===========================================
# Next.js Configuration
# ===========================================
ALLOWED_ORIGINS=localhost:3000,system2-ml.vercel.app,system2ml.vercel.app

# ===========================================
# External Services (Optional)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Feature Flags
# ===========================================
ENABLE_FINETUNING=false
ENABLE_MONITORING=true
